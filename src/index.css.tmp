:root {
  --bg:#0e1117; --bg2:#151b27; --bg3:#1c2436;
  --surface:#1e2a3a; --surface2:#243044;
  --border:rgba(255,255,255,0.07); --border-gold:rgba(255,185,50,0.35);
  --gold:#FFB932; --gold-bright:#FFD166; --gold-dim:#996B00;
  --orange:#FF6B35; --orange-dim:rgba(255,107,53,0.15);
  --blue:#4EA8DE; --blue-dim:rgba(78,168,222,0.15);
  --purple:#9B59B6; --purple-dim:rgba(155,89,182,0.15);
  --green:#2ECC71; --green-dim:rgba(46,204,113,0.15);
  --red:#E74C3C; --red-dim:rgba(231,76,60,0.15);
  --t1:#F0F4FF; --t2:#8B9BB4; --t3:#5A6A82;
  --glow-gold:0 0 20px rgba(255,185,50,0.3);
  --shadow:0 4px 24px rgba(0,0,0,0.4);
  --r:12px; --r-sm:8px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--t1);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 10% 0%,rgba(255,107,53,0.06) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 90% 100%,rgba(78,168,222,0.06) 0%,transparent 60%),radial-gradient(ellipse 40% 60% at 50% 50%,rgba(155,89,182,0.04) 0%,transparent 70%);pointer-events:none;z-index:0}

@keyframes in-up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes glow-cycle{0%,100%{box-shadow:0 0 12px rgba(255,185,50,.2)}50%{box-shadow:0 0 28px rgba(255,185,50,.5)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes bar-fill{from{width:0}to{width:var(--w)}}
@keyframes badge-pop{0%{transform:scale(0)}70%{transform:scale(1.25)}100%{transform:scale(1)}}
@keyframes emoji-float{from{opacity:1;transform:translateY(0) scale(1)}to{opacity:0;transform:translateY(-50px) scale(1.8)}}
@keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-8px)}40%{transform:translateX(8px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}

::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--surface2);border-radius:99px}
::-webkit-scrollbar-thumb:hover{background:var(--gold-dim)}

/* AUTH */
.auth-wrap{display:flex;height:100vh;justify-content:center;align-items:center;position:relative;z-index:1}
.auth-card{background:var(--bg2);border:1px solid var(--border-gold);border-radius:var(--r);padding:50px;width:100%;max-width:440px;text-align:center;animation:in-up .5s ease forwards;box-shadow:var(--shadow)}
.auth-logo{font-size:2.8rem;margin-bottom:6px;font-family:'Cinzel',serif;font-weight:700;background:linear-gradient(135deg,var(--gold-bright),var(--orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:2px}
.auth-sub{color:var(--t3);font-weight:700;letter-spacing:1px;margin-bottom:36px;font-size:.85rem}
.auth-form{display:flex;flex-direction:column;gap:16px}
.auth-input{padding:14px 16px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--bg3);font-family:'Nunito',sans-serif;font-size:.92rem;color:var(--t1);outline:none;transition:.2s}
.auth-input::placeholder{color:var(--t3)}
.auth-input:focus{border-color:rgba(255,185,50,.5);background:var(--surface);box-shadow:0 0 0 3px rgba(255,185,50,.08)}
.auth-error{color:var(--orange);font-size:.85rem;font-weight:700}
.auth-btn{padding:14px;border-radius:var(--r-sm);border:none;background:linear-gradient(135deg,var(--orange),var(--gold));color:#fff;font-family:'Rajdhani',sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:1px;cursor:pointer;transition:.18s;text-transform:uppercase;box-shadow:0 4px 16px rgba(255,107,53,.3);margin-top:8px}
.auth-btn:hover{transform:translateY(-1px);box-shadow:0 6px 22px rgba(255,107,53,.45)}
.auth-toggle{margin-top:24px;color:var(--t3);cursor:pointer;font-weight:700;font-size:.85rem}
.auth-toggle:hover{color:var(--gold)}

/* LOADING */
.loading-wrap{display:flex;height:100vh;justify-content:center;align-items:center;flex-direction:column;gap:16px;z-index:1;position:relative}
.loading-wrap h2{font-family:'Cinzel',serif;color:var(--gold);letter-spacing:3px;animation:pulse 2s infinite}

/* TOPNAV */
.topnav{position:fixed;top:0;left:0;right:0;z-index:1000;height:58px;background:rgba(14,17,23,0.92);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-bottom:1px solid var(--border-gold);display:flex;align-items:center;padding:0 20px;gap:14px}
.logo{display:flex;align-items:center;gap:9px;cursor:pointer;flex-shrink:0}
.logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--orange),var(--gold));border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:18px;animation:glow-cycle 3s ease-in-out infinite}
.logo-text{font-family:'Cinzel',serif;font-size:1.18rem;font-weight:700;background:linear-gradient(135deg,var(--gold-bright),var(--orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:1px}
.nav-search{flex:1;max-width:350px;position:relative}
.nav-search input{width:100%;height:36px;background:var(--surface);border:1px solid var(--border);border-radius:99px;padding:0 16px 0 38px;font-family:'Nunito',sans-serif;font-size:.85rem;color:var(--t1);outline:none;transition:.2s}
.nav-search input::placeholder{color:var(--t3)}
.nav-search input:focus{border-color:rgba(255,185,50,.5);background:var(--bg3);box-shadow:0 0 0 3px rgba(255,185,50,.08)}
.nav-search .si{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:15px;pointer-events:none}
.nav-tabs{display:flex;align-items:center;gap:2px}
.ntab{display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:var(--r-sm);border:none;background:transparent;color:var(--t2);font-family:'Nunito',sans-serif;font-size:.8rem;font-weight:700;cursor:pointer;transition:.18s;white-space:nowrap}
.ntab:hover{background:var(--surface);color:var(--t1)}
.ntab.active{background:var(--orange-dim);color:var(--orange)}
.nav-right{display:flex;align-items:center;gap:8px;margin-left:auto}
.nav-ico{position:relative;width:38px;height:38px;border-radius:99px;border:none;background:var(--surface);color:var(--t2);font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.18s}
.nav-ico:hover{background:var(--surface2);color:var(--t1)}
.nav-badge{position:absolute;top:3px;right:3px;min-width:17px;height:17px;border-radius:99px;background:var(--red);color:#fff;font-size:9px;font-weight:900;display:flex;align-items:center;justify-content:center;border:2px solid var(--bg);animation:badge-pop .4s cubic-bezier(.34,1.56,.64,1) forwards;padding:0 3px}
.nav-user{display:flex;align-items:center;gap:9px;padding:4px 12px 4px 4px;border-radius:99px;background:var(--surface);border:1px solid var(--border-gold);cursor:pointer;transition:.18s}
.nav-user:hover{background:var(--surface2)}
.nav-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--orange),var(--gold));display:flex;align-items:center;justify-content:center;font-size:16px;position:relative;flex-shrink:0}
.nav-av::after{content:'';position:absolute;bottom:0;right:0;width:9px;height:9px;background:var(--green);border-radius:50%;border:2px solid var(--bg)}
.nav-uname{font-size:.8rem;font-weight:800;color:var(--t1);line-height:1.2}
.nav-ulevel{font-size:.65rem;color:var(--gold);font-weight:700;font-family:'Rajdhani',sans-serif;letter-spacing:.5px}

/* PAGE LAYOUT */
.page{max-width:1280px;margin:0 auto;padding:78px 16px 48px;display:grid;grid-template-columns:270px 1fr 280px;gap:18px;position:relative;z-index:1}

/* CARDS */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:border-color .2s,box-shadow .2s}
.card:hover{border-color:var(--border-gold)}
.ch{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;border-bottom:1px solid var(--border)}
.ch-title{font-family:'Rajdhani',sans-serif;font-size:.8rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--t2);display:flex;align-items:center;gap:7px}
.ch-title .dot-accent{width:6px;height:6px;border-radius:50%;background:var(--gold);box-shadow:0 0 6px var(--gold)}
.ch-action{font-size:.72rem;font-weight:800;color:var(--gold);cursor:pointer;opacity:.8;transition:opacity .18s}
.ch-action:hover{opacity:1}

/* LEFT COL */
.left-col{display:flex;flex-direction:column;gap:14px}
.profile-card{animation:in-up .5s ease forwards}
.profile-banner{height:80px;position:relative;overflow:hidden;background:linear-gradient(135deg,#1a0a00,#2d1500 40%,#1a1a2e)}
.profile-banner::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,107,53,.4),rgba(255,185,50,.2),rgba(78,168,222,.2));background-size:300% 300%;animation:shimmer 4s linear infinite}
.profile-banner-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:4px;color:rgba(255,185,50,.4);white-space:nowrap;text-transform:uppercase}
.profile-av-wrap{display:flex;justify-content:space-between;align-items:flex-end;padding:0 16px;margin-top:-28px;margin-bottom:12px}
.profile-av{width:58px;height:58px;border-radius:50%;border:3px solid var(--bg2);background:linear-gradient(135deg,var(--orange),var(--gold));display:flex;align-items:center;justify-content:center;font-size:28px;box-shadow:var(--glow-gold);position:relative;flex-shrink:0}
.profile-av .online-ring{position:absolute;inset:-4px;border-radius:50%;border:2px solid var(--green);box-shadow:0 0 8px var(--green)}
.faction-badge{display:flex;align-items:center;gap:5px;padding:4px 11px;border-radius:99px;font-size:.65rem;font-weight:800;font-family:'Rajdhani',sans-serif;letter-spacing:1px;text-transform:uppercase}
.faction-guardians{background:rgba(30,80,180,.25);border:1px solid rgba(60,130,220,.4);color:#80b8ff}
.faction-raiders{background:rgba(180,30,30,.25);border:1px solid rgba(220,60,60,.4);color:#ff8080}
.faction-ghosts{background:rgba(100,30,180,.25);border:1px solid rgba(155,89,182,.4);color:#c49bde}
.profile-body{padding:0 16px 16px}
.profile-name{font-family:'Rajdhani',sans-serif;font-size:1.15rem;font-weight:700;color:var(--t1);letter-spacing:.5px;margin-bottom:1px}
.profile-title{font-size:.72rem;color:var(--gold);font-weight:700;margin-bottom:6px;font-family:'Rajdhani',sans-serif;letter-spacing:.5px}
.profile-bio{font-size:.78rem;color:var(--t2);line-height:1.55;margin-bottom:14px;font-style:italic}
.xp-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px}
.xp-label{font-family:'Rajdhani',sans-serif;font-size:.68rem;font-weight:700;color:var(--t3);letter-spacing:1px;text-transform:uppercase}
.xp-val{font-family:'Rajdhani',sans-serif;font-size:.72rem;font-weight:700;color:var(--gold)}
.bar-track{height:6px;background:var(--bg3);border-radius:99px;overflow:hidden;margin-bottom:14px;position:relative}
.bar-fill{height:100%;border-radius:99px;transition:width .6s cubic-bezier(.22,1,.36,1)}
.bar-xp{background:linear-gradient(90deg,var(--gold-dim),var(--gold))}
.bar-energy{background:linear-gradient(90deg,#0d2a6b,var(--blue))}
.bar-hp{background:linear-gradient(90deg,#1a6b35,var(--green))}
.bar-danger{background:linear-gradient(90deg,#6b1a1a,var(--red))}
.stats-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:13px}
.stat-box{background:var(--bg3);border-radius:var(--r-sm);padding:9px 6px;text-align:center;cursor:pointer;transition:.18s;border:1px solid transparent}
.stat-box:hover{border-color:var(--border-gold);background:var(--surface)}
.stat-val{font-family:'Rajdhani',sans-serif;font-size:1.1rem;font-weight:700;color:var(--gold-bright);display:block;line-height:1.1}
.stat-key{font-size:.6rem;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.karma-strip{display:flex;align-items:center;gap:8px;padding:10px 13px;border-radius:var(--r-sm);background:linear-gradient(135deg,rgba(255,185,50,.08),rgba(255,107,53,.06));border:1px solid var(--border-gold);margin-bottom:12px}
.karma-icon{font-size:20px;animation:float 3s ease-in-out infinite}
.karma-info{flex:1}
.karma-label{font-size:.6rem;color:var(--t3);text-transform:uppercase;letter-spacing:1px;font-weight:700}
.karma-val{font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;color:var(--gold-bright)}
.karma-tier{font-size:.62rem;padding:3px 9px;border-radius:99px;background:rgba(255,185,50,.15);color:var(--gold);font-weight:800;border:1px solid rgba(255,185,50,.3)}
.btn-outline{width:100%;padding:9px;border-radius:var(--r-sm);border:1px solid var(--border-gold);background:transparent;color:var(--gold);font-family:'Nunito',sans-serif;font-size:.82rem;font-weight:800;cursor:pointer;transition:.18s;letter-spacing:.3px}
.btn-outline:hover{background:rgba(255,185,50,.1);box-shadow:var(--glow-gold)}

/* ACHIEVEMENTS */
.ach-list{display:flex;flex-direction:column}
.ach-item{display:flex;align-items:center;gap:11px;padding:11px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .18s}
.ach-item:last-child{border-bottom:none}
.ach-item:hover{background:var(--bg3)}
.ach-icon{width:38px;height:38px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.ach-icon.gold{background:rgba(255,185,50,.12);border:1px solid rgba(255,185,50,.3)}
.ach-icon.epic{background:rgba(155,89,182,.15);border:1px solid rgba(155,89,182,.3)}
.ach-icon.silver{background:rgba(180,190,210,.1);border:1px solid rgba(180,190,210,.2)}
.ach-info{flex:1;min-width:0}
.ach-name{font-size:.8rem;font-weight:800;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ach-desc{font-size:.67rem;color:var(--t3);margin-top:1px}
.ach-pts{font-family:'Rajdhani',sans-serif;font-size:.72rem;font-weight:700;color:var(--gold);white-space:nowrap}

/* FEED */
.feed{display:flex;flex-direction:column;gap:14px}
.composer{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:16px;animation:in-up .4s ease forwards;transition:border-color .2s}
.comp-top{display:flex;gap:11px;margin-bottom:12px}
.comp-av{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--orange),var(--gold));display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;border:2px solid rgba(255,185,50,.3)}
.comp-input{flex:1;min-height:72px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-sm);padding:11px 14px;font-family:'Nunito',sans-serif;font-size:.9rem;color:var(--t1);resize:none;outline:none;transition:.2s;line-height:1.55}
.comp-input::placeholder{color:var(--t3)}
.comp-input:focus{border-color:rgba(255,185,50,.4);background:var(--surface);box-shadow:0 0 0 3px rgba(255,185,50,.06)}
.comp-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.comp-tools{display:flex;gap:4px;flex-wrap:wrap}
.comp-tool{display:flex;align-items:center;gap:5px;padding:6px 11px;border-radius:var(--r-sm);border:1px solid var(--border);background:transparent;color:var(--t2);font-family:'Nunito',sans-serif;font-size:.75rem;font-weight:700;cursor:pointer;transition:.18s}
.comp-tool:hover{border-color:rgba(255,185,50,.4);color:var(--gold);background:rgba(255,185,50,.06)}
.comp-tool.active{border-color:var(--orange);color:var(--orange);background:var(--orange-dim)}
.btn-post{display:flex;align-items:center;gap:6px;padding:9px 22px;border-radius:var(--r-sm);border:none;background:linear-gradient(135deg,var(--orange),var(--gold));color:#fff;font-family:'Rajdhani',sans-serif;font-size:.92rem;font-weight:700;letter-spacing:1px;cursor:pointer;transition:.18s;text-transform:uppercase;box-shadow:0 4px 16px rgba(255,107,53,.3)}
.btn-post:hover{transform:translateY(-1px);box-shadow:0 6px 22px rgba(255,107,53,.45)}
.btn-post:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.feed-tabs{display:flex;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.ftab{flex:1;padding:11px 8px;text-align:center;font-size:.75rem;font-weight:800;color:var(--t3);cursor:pointer;border-bottom:2px solid transparent;transition:.18s;display:flex;align-items:center;justify-content:center;gap:5px;letter-spacing:.3px;background:none;border-top:none;border-left:none;border-right:none;font-family:'Nunito',sans-serif}
.ftab:hover{color:var(--t1);background:var(--bg3)}
.ftab.active{color:var(--gold);border-bottom-color:var(--gold);background:rgba(255,185,50,.05)}

/* POSTS */
.post{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:border-color .2s,transform .2s,box-shadow .2s;animation:in-up .5s ease forwards}
.post:hover{border-color:var(--border-gold);transform:translateY(-1px);box-shadow:var(--shadow)}
.post.shake-hard{animation:shake .5s ease}
.post.dead-post{opacity:.6}
.post-guild-bar{display:flex;align-items:center;gap:8px;padding:8px 16px;border-bottom:1px solid var(--border);font-size:.72rem;font-weight:800;color:var(--t2)}
.post-guild-bar .guild-dot{width:6px;height:6px;border-radius:50%}
.post-guild-bar strong{cursor:pointer}
.post-guild-bar strong:hover{text-decoration:underline}
.post-head{display:flex;align-items:flex-start;gap:11px;padding:14px 16px 10px}
.post-av{width:46px;height:46px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:22px;position:relative;border:2px solid var(--border);cursor:pointer;transition:.18s;font-weight:900;color:#fff}
.post-av:hover{border-color:var(--gold)}
.post-meta{flex:1}
.post-meta-top{display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:3px}
.post-author{font-weight:900;font-size:.92rem;color:var(--t1);cursor:pointer;background:none;border:none;font-family:'Nunito',sans-serif;padding:0}
.post-author:hover{color:var(--gold)}
.chip{font-size:.6rem;font-weight:800;padding:2px 8px;border-radius:99px;font-family:'Rajdhani',sans-serif;letter-spacing:.8px;text-transform:uppercase}
.chip-orange{background:var(--orange-dim);color:var(--orange);border:1px solid rgba(255,107,53,.3)}
.chip-blue{background:var(--blue-dim);color:var(--blue);border:1px solid rgba(78,168,222,.3)}
.chip-purple{background:var(--purple-dim);color:var(--purple);border:1px solid rgba(155,89,182,.3)}
.chip-green{background:var(--green-dim);color:var(--green);border:1px solid rgba(46,204,113,.3)}
.chip-gold{background:rgba(255,185,50,.12);color:var(--gold);border:1px solid rgba(255,185,50,.3)}
.chip-red{background:var(--red-dim);color:var(--red);border:1px solid rgba(231,76,60,.3)}
.post-time{font-size:.68rem;color:var(--t3)}
.post-body{padding:2px 16px 12px;font-size:.9rem;line-height:1.68;color:var(--t2)}
.post-body strong{color:var(--t1);font-weight:800}
.glitch-text{color:var(--red);font-family:'Rajdhani',sans-serif;letter-spacing:2px;text-transform:uppercase;font-weight:700}

/* HP BAR IN POST */
.bunker-hp{padding:0 16px 12px}
.hp-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;font-size:.72rem;font-weight:700;font-family:'Rajdhani',sans-serif;color:var(--t3);letter-spacing:1px}
.shield-count{color:var(--green);font-size:.7rem;display:flex;align-items:center;gap:4px}

/* POST ACTIONS */
.post-divider{border:none;border-top:1px solid var(--border);margin:0 16px}
.post-actions{display:flex;padding:2px 8px}
.pact{flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:9px 6px;border:none;background:transparent;color:var(--t3);font-family:'Nunito',sans-serif;font-size:.75rem;font-weight:800;cursor:pointer;border-radius:var(--r-sm);transition:.15s}
.pact:hover{background:var(--bg3);color:var(--gold)}
.pact:disabled{opacity:.3;cursor:not-allowed}
.pact.pact-attack:hover{color:var(--red)}
.pact.pact-defend:hover{color:var(--green)}
.pact .cnt{color:var(--t3);font-weight:600}

/* COMMENTS */
.comments-section{padding:0 16px 16px}
.comments-section h4{font-size:.75rem;color:var(--t3);margin-bottom:10px;font-weight:700;letter-spacing:.5px}
.comment-item{padding:8px 12px;background:var(--bg3);border-radius:var(--r-sm);margin-bottom:6px;font-size:.85rem}
.comment-author{font-weight:800;color:var(--gold);margin-right:8px;cursor:pointer;font-size:.8rem}
.comment-author:hover{text-decoration:underline}
.comment-text{color:var(--t2)}
.comment-form{display:flex;gap:8px;margin-top:8px}
.comment-input{flex:1;padding:8px 14px;border-radius:99px;border:1px solid var(--border);background:var(--bg3);color:var(--t1);font-family:'Nunito',sans-serif;font-size:.82rem;outline:none;transition:.2s}
.comment-input::placeholder{color:var(--t3)}
.comment-input:focus{border-color:rgba(255,185,50,.4);background:var(--surface)}
.comment-send{background:linear-gradient(135deg,var(--orange),var(--gold));color:#fff;border:none;border-radius:99px;padding:0 18px;font-weight:800;cursor:pointer;font-size:.78rem;transition:.18s;font-family:'Nunito',sans-serif}
.comment-send:disabled{opacity:.4;cursor:not-allowed}
.comment-send:hover:not(:disabled){transform:scale(1.05)}

/* RIGHT COL */
.right-col{display:flex;flex-direction:column;gap:14px}

/* RADAR */
.radar-list{display:flex;flex-direction:column;max-height:300px;overflow-y:auto;padding:0 12px 12px}
.radar-item{font-size:.82rem;padding:10px;background:var(--bg3);border-radius:var(--r-sm);margin-bottom:6px;border-left:3px solid var(--t3)}
.radar-item.type-attack{border-left-color:var(--red)}
.radar-item.type-defend{border-left-color:var(--green)}
.radar-item.type-deploy{border-left-color:var(--gold)}
.radar-actor{font-weight:800;color:var(--t1);cursor:pointer}
.radar-actor:hover{color:var(--gold)}
.radar-detail{color:var(--t3);font-size:.78rem}
.radar-time{font-size:.65rem;color:var(--t3);margin-top:4px;opacity:.7}

/* ARSENAL */
.arsenal-grid{display:flex;flex-direction:column;gap:6px;padding:12px}
.weapon-btn{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--bg3);cursor:pointer;transition:.18s;color:var(--t2);width:100%;font-family:'Nunito',sans-serif;font-size:.8rem;font-weight:700}
.weapon-btn:hover{border-color:var(--border-gold);background:var(--surface)}
.weapon-btn.selected{border-color:var(--gold);background:rgba(255,185,50,.08);color:var(--gold-bright)}
.weapon-icon{font-size:1.4rem}
.weapon-info{flex:1;text-align:left}
.weapon-name{font-family:'Rajdhani',sans-serif;font-size:.85rem;font-weight:700;color:var(--t1)}
.weapon-stats{font-size:.65rem;color:var(--t3)}
.weapon-cost{font-family:'Rajdhani',sans-serif;font-size:.8rem;font-weight:700;color:var(--orange)}

/* RANKING */
.ranking-list{display:flex;flex-direction:column}
.rank-item{display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .18s}
.rank-item:last-child{border-bottom:none}
.rank-item:hover{background:var(--bg3)}
.rank-item.me{background:rgba(255,185,50,.05);border-left:3px solid var(--gold)}
.rank-pos{font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;width:24px;text-align:center;flex-shrink:0}
.rank-pos.gold-pos{color:var(--gold);text-shadow:0 0 8px var(--gold)}
.rank-pos.silver-pos{color:#b0bec5}
.rank-pos.bronze-pos{color:#a1887f}
.rank-pos.normal-pos{color:var(--t3)}
.rank-av{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;font-weight:900;color:#fff}
.rank-info{flex:1;min-width:0}
.rank-name{font-size:.8rem;font-weight:800;color:var(--t1)}
.rank-sub{font-size:.62rem;color:var(--t3)}
.rank-score{font-family:'Rajdhani',sans-serif;font-size:.85rem;font-weight:700;color:var(--gold-bright)}

/* RECADO */
.recado-form{padding:13px 16px 15px}
.recado-form textarea{width:100%;height:68px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-sm);padding:10px 12px;font-family:'Nunito',sans-serif;font-size:.82rem;color:var(--t1);resize:none;outline:none;transition:.2s;margin-bottom:9px}
.recado-form textarea:focus{border-color:rgba(255,185,50,.4);background:var(--surface)}
.recado-form textarea::placeholder{color:var(--t3)}
.btn-primary{width:100%;padding:9px;border-radius:var(--r-sm);border:none;background:linear-gradient(135deg,var(--orange),var(--gold));color:#fff;font-family:'Rajdhani',sans-serif;font-size:.88rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:.18s;box-shadow:0 3px 14px rgba(255,107,53,.3)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(255,107,53,.45)}

/* EVENTS */
.event-list{display:flex;flex-direction:column}
.event-item{display:flex;gap:11px;align-items:center;padding:11px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .18s}
.event-item:last-child{border-bottom:none}
.event-item:hover{background:var(--bg3)}
.ev-day{font-family:'Rajdhani',sans-serif;font-size:1.1rem;font-weight:700;color:var(--gold-bright);line-height:1;text-align:center}
.ev-mon{font-size:.58rem;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.5px;text-align:center}
.event-info{flex:1;min-width:0}
.ev-name{font-size:.8rem;font-weight:800;color:var(--t1);margin-bottom:2px}
.ev-sub{font-size:.65rem;color:var(--t3)}
.ev-type{font-size:.6rem;font-weight:800;padding:3px 8px;border-radius:99px;font-family:'Rajdhani',sans-serif;letter-spacing:.5px;text-transform:uppercase}

/* PROJECTILES / EXPLOSIONS */
.projectile{position:fixed;z-index:9999;font-size:1.4rem;pointer-events:none;transition:transform .4s cubic-bezier(.1,.8,.1,1)}
.explosion-ring{position:fixed;z-index:9998;width:60px;height:60px;border-radius:50%;background:radial-gradient(circle,rgba(255,107,53,.6),transparent 70%);transform:translate(-50%,-50%);pointer-events:none;animation:emoji-float .5s ease forwards}

/* MODALS */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);z-index:2000;display:flex;justify-content:center;align-items:center;animation:in-up .3s ease}
.modal-panel{background:var(--bg2);border:1px solid var(--border-gold);border-radius:var(--r);max-width:600px;width:95%;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.6);padding:40px}
.modal-panel h2{font-family:'Rajdhani',sans-serif;color:var(--t1);font-size:1.8rem;margin-bottom:4px}
.modal-subtitle{color:var(--gold);font-family:'Rajdhani',sans-serif;font-weight:700;letter-spacing:2px;font-size:.8rem;margin-bottom:30px}
.modal-stats{display:flex;gap:14px;margin-bottom:30px}
.modal-stat{flex:1;padding:18px;background:var(--bg3);border-radius:var(--r-sm);text-align:center}
.modal-stat-val{font-family:'Rajdhani',sans-serif;font-size:1.8rem;font-weight:900}
.modal-stat-key{font-size:.7rem;color:var(--t3);font-weight:700;text-transform:uppercase;margin-top:4px}
.modal-medals{display:flex;gap:12px;margin-bottom:30px}
.modal-medal{flex:1;padding:16px;background:var(--bg3);border-radius:var(--r-sm);text-align:center;border:1px solid var(--border);transition:.18s}
.modal-medal.earned{border-color:var(--border-gold);background:rgba(255,185,50,.05)}
.modal-medal.locked{opacity:.3}
.modal-medal-icon{font-size:1.8rem;margin-bottom:8px}
.modal-medal-name{font-size:.75rem;font-weight:800;color:var(--t1)}
.modal-actions{display:flex;gap:12px}
.modal-btn{flex:1;padding:12px;border-radius:var(--r-sm);border:none;font-family:'Rajdhani',sans-serif;font-size:.9rem;font-weight:700;letter-spacing:1px;cursor:pointer;transition:.18s;text-transform:uppercase}
.modal-btn-primary{background:linear-gradient(135deg,var(--orange),var(--gold));color:#fff;box-shadow:0 4px 14px rgba(255,107,53,.3)}
.modal-btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(255,107,53,.45)}
.modal-btn-ghost{background:transparent;border:1px solid var(--border);color:var(--t2)}
.modal-btn-ghost:hover{border-color:var(--border-gold);color:var(--t1)}

/* SKILL TREE MODAL */
.skill-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:20px 0}
.skill-node{padding:16px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-sm);cursor:pointer;transition:.18s;text-align:center}
.skill-node:hover{border-color:var(--border-gold);background:var(--surface)}
.skill-node.unlocked{border-color:var(--gold);background:rgba(255,185,50,.08)}
.skill-node-icon{font-size:1.6rem;margin-bottom:6px}
.skill-node-name{font-family:'Rajdhani',sans-serif;font-size:.85rem;font-weight:700;color:var(--t1);margin-bottom:2px}
.skill-node-desc{font-size:.65rem;color:var(--t3)}
.skill-node-cost{font-family:'Rajdhani',sans-serif;font-size:.75rem;font-weight:700;color:var(--gold);margin-top:6px}

/* FACTION SELECTOR */
.faction-picker{display:flex;gap:6px;padding:12px}
.faction-btn{flex:1;padding:10px 8px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--bg3);cursor:pointer;transition:.18s;text-align:center;font-family:'Rajdhani',sans-serif;font-size:.75rem;font-weight:700;color:var(--t2);letter-spacing:.5px}
.faction-btn:hover{border-color:var(--border-gold)}
.faction-btn.selected{border-width:2px}

/* RESPONSIVE */
@media(max-width:1100px){.page{grid-template-columns:240px 1fr}.right-col{display:none}}
@media(max-width:700px){.page{grid-template-columns:1fr;padding-top:74px}.left-col{display:none}.nav-tabs{display:none}}
